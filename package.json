{
  "name": "tiv-rajasthan",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/node": "^22.13.14",
      "next-themes": "^0.4.6",
      "react": "^19.2.6",
      "react-dom": "^19.2.6",
      "@orpc/server": "^1.13.14",
      "@orpc/client": "^1.13.14",
      "@orpc/openapi": "^1.13.14",
      "@orpc/zod": "^1.13.14",
      "better-auth": "1.6.11",
      "@types/react": "^19.2.15",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "nx run-many -t dev",
    "build": "nx run-many -t build",
    "check-types": "nx run-many -t check-types",
    "dev:web": "nx run-many -t dev --projects=web",
    "db:push": "nx run-many -t db:push --projects=@tiv-rajasthan/db",
    "db:studio": "nx run-many -t db:studio --projects=@tiv-rajasthan/db",
    "db:generate": "nx run-many -t db:generate --projects=@tiv-rajasthan/db",
    "db:migrate": "nx run-many -t db:migrate --projects=@tiv-rajasthan/db",
    "db:start": "nx run-many -t db:start --projects=@tiv-rajasthan/db",
    "db:watch": "nx run-many -t db:watch --projects=@tiv-rajasthan/db",
    "db:stop": "nx run-many -t db:stop --projects=@tiv-rajasthan/db",
    "db:down": "nx run-many -t db:down --projects=@tiv-rajasthan/db",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@tiv-rajasthan/env": "workspace:*",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@tiv-rajasthan/config": "workspace:*",
    "@types/node": "^22.19.19",
    "nx": "^21.6.11",
    "typescript": "^6.0.3",
    "ultracite": "7.7.0"
  },
  "packageManager": "bun@1.3.14"
}
